function proximaEtapa(){

    const respostas = {

        historia:
            document.getElementById("historia").value,

        motivacao:
            document.getElementById("motivacao").value,

        lembrada:
            document.getElementById("lembrada").value,

        diferencial:
            document.getElementById("diferencial").value

    };

    localStorage.setItem(
        "plannerHila",
        JSON.stringify(respostas)
    );

    alert("Etapa 1 salva com sucesso!");

    console.log(respostas);

}